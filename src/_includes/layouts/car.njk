<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ title }} — Cooker's Restoration &amp; Fabrication</title>
  <meta name="description" content="{{ title }} — VW restoration by Cooker's Restoration &amp; Fabrication, Williamsport MD."/>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=Playfair+Display:ital@1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../css/style.css">
  <link rel="stylesheet" href="../css/lightbox.css">
  <style>
    .car-hero { position:relative; margin-top:var(--header-h); height:380px; overflow:hidden; }
    .car-hero img { width:100%;height:100%;object-fit:cover;object-position:center 35%;filter:saturate(0.8) brightness(0.7); }
    .car-hero-overlay { position:absolute;inset:0;background:linear-gradient(to top,rgba(26,63,92,.9) 0%,rgba(26,63,92,.35) 60%,rgba(26,63,92,.1) 100%); }
    .car-hero-content { position:absolute;bottom:0;left:0;right:0;padding:2rem 4rem; }
    .car-breadcrumb { font-size:.65rem;letter-spacing:2.5px;text-transform:uppercase;color:rgba(245,240,232,.5);margin-bottom:.5rem; }
    .car-breadcrumb a { color:rgba(245,240,232,.5);text-decoration:none; }
    .car-breadcrumb a:hover { color:white; }
    .car-desc { font-size:.95rem;font-weight:300;line-height:1.8;color:var(--mid-gray);max-width:860px;margin:1rem 0 2rem; }
    .car-meta { display:flex;gap:1.5rem;align-items:center;flex-wrap:wrap;margin-bottom:1.5rem; }
    .car-category { font-size:.65rem;font-weight:500;letter-spacing:2.5px;text-transform:uppercase;color:var(--light-gray); }
    .car-count { font-size:.65rem;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--light-gray); }
    @media(max-width:720px){.car-hero{height:260px;}.car-hero-content{padding:1.5rem 1.25rem;}}
  </style>
</head>
<body>

{% set isCarPage = true %}
{% include "partials/header.njk" %}

<!-- CAR HERO -->
<div class="car-hero">
  <img src="{{ (hero_image | default(gallery[0].image if gallery and gallery[0] else 'header_images/1425922475.jpg')) | imageUrl }}" alt="{{ title }}"
    onerror="this.src='../optimized_images/header_images/1425922475.jpg'"/>
  <div class="car-hero-overlay"></div>
  <div class="car-hero-content">
    <div class="car-breadcrumb">
      <a href="../index.html">Home</a> &rsaquo; <a href="{{ status | backLink }}">{{ status | backLinkText }}</a> &rsaquo; {{ title }}
    </div>
    <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:.5rem;">
      <span class="card-status {{ status | statusClass }}">{{ status | statusText }}</span>
      <span style="font-size:.63rem;letter-spacing:3px;text-transform:uppercase;color:rgba(245,240,232,.5);">{{ model | modelDisplay }}</span>
    </div>
    <h1 style="font-size:clamp(1.8rem,4vw,3rem);margin-bottom:0;">{{ title }}</h1>
  </div>
</div>

<!-- GALLERY SECTION -->
<section class="section section-cream">
  <div class="car-meta">
    <a href="{{ status | backLink }}" class="btn btn-blue" style="font-size:.72rem;">&larr; Back to {{ status | backLinkText }}</a>
    <span class="car-count">{{ gallery | length }} Photos</span>
  </div>

  {% if description %}
  <p class="car-desc">{{ description }}</p>
  {% endif %}

  <div class="thumb-grid">
    {% for photo in gallery %}
    <div class="thumb-item"
         data-src="{{ photo.image | imageUrl }}"
         data-full-src="{{ photo.image | imageUrl }}"
         data-alt="{{ title }}{% if photo.caption %} - {{ photo.caption }}{% endif %}">
      <img src="{{ photo.image | imageUrl }}" alt="{{ title }}{% if photo.caption %} - {{ photo.caption }}{% endif %}" loading="lazy"/>
      <div class="thumb-overlay">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6"/>
        </svg>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<!-- RELATED CTA -->
<section class="about-strip">
  <div class="about-img-wrap">
    <div class="about-img-overlay"></div>
  </div>
  <div class="about-content">
    <div class="section-label">Start Your Build</div>
    <h2>Your Car<br/>Could Be Next.</h2>
    <p>Every project in our gallery started as a dream — and a phone call. Bring us yours and let's talk about what's possible.</p>
    <div style="display:flex;gap:1rem;flex-wrap:wrap;">
      <a href="../contact.html" class="btn btn-primary">Get In Touch</a>
      <a href="../the-cars.html" class="btn btn-outline">See More Builds</a>
    </div>
  </div>
</section>

{% include "partials/footer.njk" %}

<script src="../js/main.js"></script>
<script src="../js/lightbox.js"></script>
</body>
</html>
